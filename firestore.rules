/**
 * This ruleset enforces a strict user-ownership model for a ClassTrack attendance application.
 *
 * Core Philosophy:
 * The security model is built on the principle that users have complete control over their own
 * data, and absolutely no access to the data of other users. All operations are authorized
 * based on the authenticated user's unique ID (UID).
 *
 * Data Structure:
 * All user-specific data is hierarchically organized and isolated under the `/users/{userId}`
 * path. For example, a user's academic subjects are stored in a subcollection at
 * `/users/{userId}/subjects/{subjectId}`. This structure is fundamental to the security model.
 *
 * Key Security Decisions:
 * - User Isolation: A user can only read or write documents within their own data tree
 *   (i.e., where the `{userId}` in the path matches their `request.auth.uid`).
 * - No User Listing: It is not possible for any client to list all documents in the top-level
 *   `/users` collection, protecting user privacy.
 * - Ownership is Path-Based: Authorization relies on the `{userId}` wildcard in the document
 *   path. This avoids costly `get()` calls to other documents and makes the rules highly
 *   performant and simple to audit.
 * - Default Deny: Any path not explicitly defined in these rules is inaccessible.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user's UID matches the provided userId from the path.
     * This is the primary function for establishing ownership.
     * @param userId The user ID from the document path.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * A stricter ownership check for update and delete operations.
     * It verifies ownership AND ensures the document already exists.
     * @param userId The user ID from the document path.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    /**
     * @description Rules for the user document root. This allows a user to create their
     *              own user document but prevents them from seeing or interacting with
     *              any other user's document. Listing all users is explicitly denied.
     * @path        /users/{userId}
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if false;
    }

    /**
     * @description Rules for a user's private 'subjects' collection.
     * @path        /users/{userId}/subjects
     */
    match /users/{userId}/subjects {
      allow list, create: if isOwner(userId);
    }

    /**
     * @description Rules for a user's private 'subjects' documents.
     * @path        /users/{userId}/subjects/{subjectId}
     */
    match /users/{userId}/subjects/{subjectId} {
      allow get: if isOwner(userId);
      allow update, delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for a subject's 'attendance' subcollection.
     * @path        /users/{userId}/subjects/{subjectId}/attendance
     */
    match /users/{userId}/subjects/{subjectId}/attendance {
      allow list, create: if isOwner(userId);
    }

    /**
     * @description Rules for individual 'attendance' documents.
     * @path        /users/{userId}/subjects/{subjectId}/attendance/{attendanceId}
     */
    match /users/{userId}/subjects/{subjectId}/attendance/{attendanceId} {
      allow get, update, delete: if isOwner(userId);
    }
  }
}
