{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's profile.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "URL of the user's profile picture."
        }
      },
      "required": [
        "email"
      ]
    },
    "Subject": {
      "title": "Subject",
      "description": "Represents a course or subject the user is tracking.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the subject."
        },
        "teacher": {
          "type": "string",
          "description": "The name of the teacher."
        },
        "requirement": {
          "type": "number",
          "description": "The attendance requirement as a percentage."
        },
        "totalClasses": {
          "type": "number",
          "description": "Total number of classes in the semester."
        },
        "present": {
          "type": "number",
          "description": "Number of classes attended."
        },
        "absent": {
          "type": "number",
          "description": "Number of classes missed."
        }
      },
      "required": [
        "name",
        "requirement",
        "totalClasses",
        "present",
        "absent"
      ]
    }
  },
  "auth": {
    "providers": [
      "email-password",
      "google.com"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "Stores user profile information."
    },
    "/users/{userId}/subjects/{subjectId}": {
      "schema": {
        "$ref": "#/entities/Subject"
      },
      "description": "Stores subjects for a specific user."
    }
  }
}
